{
    "name": "@repo/shared",
    "type": "module",
    "scripts": {
        "dev": "tsc --watch",
        "build": "tsc"
    },
    "devDependencies": {
        "typescript": "latest"
    },
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./types": {
            "types": "./src/types/index.ts",
            "import": "./src/types/index.ts"
        },
        "./types/*": {
            "types": "./src/types/*.ts",
            "import": "./src/types/*.ts"
        }
    }
}